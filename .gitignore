# Python 缓存
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# 屏蔽所有数据文件（极其重要！）
# 拦截 data 目录下所有的 csv, txt, xlsx 文件，无论它们藏得多深
data/**/*.csv
data/**/*.txt
data/**/*.xlsx

# 允许上传 metadata（如果需要上传那个小小的配置表，可以取消下面这行的注释）
!data/metadata/*.csv

