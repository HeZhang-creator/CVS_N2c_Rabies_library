# 导入绘图依赖
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from pathlib import Path

# ==========================================
# 全局格式设置 (Nature Methods 标准)
# ==========================================
plt.rcParams['font.family'] = 'Arial'
plt.rcParams['svg.fonttype'] = 'none'
plt.rcParams['axes.linewidth'] = 1.2

CUSTOM_COLORS = {
    'HH + HdVRz': '#1F77B4',
    'HH + Twister': '#D62728',
    'RzB + Twister': '#FF7F0E'
}

# ==========================================
# 读取 04 脚本预计算好的数据
# ==========================================
metrics_dir = Path("../data/processed/invitro_metrics") # 注意 notebook 里的相对路径可能只有一层 ../
plot_dir = Path("../plots/supplementary")
plot_dir.mkdir(parents=True, exist_ok=True)

df_scatter = pd.read_csv(metrics_dir / "fidelity_scatter_data.csv")
df_stats = pd.read_csv(metrics_dir / "fidelity_stats.csv")

groups = df_stats['Group'].unique()

# ==========================================
# 开始渲染多面板图
# ==========================================
fig, axes = plt.subplots(1, len(groups), figsize=(5 * len(groups), 5))
if len(groups) == 1: axes = [axes]

for i, group in enumerate(groups):
    ax = axes[i]
    color = CUSTOM_COLORS.get(group, '#333333')
    
    # 提取该组数据与统计值
    group_data = df_scatter[df_scatter['Group'] == group]
    stats = df_stats[df_stats['Group'] == group].iloc[0]
    
    # 1. 绘制对角线 (Perfect Fidelity Line)
    ax.plot([1e-5, 100], [1e-5, 100], 'k--', alpha=0.5, linewidth=1, zorder=1)
    
    # 2. 绘制散点图
    sns.scatterplot(
        data=group_data, x='Frequency_Plasmid', y='Frequency_EnvA',
        color=color, alpha=0.6, s=15, edgecolor=None, ax=ax, zorder=2
    )
    
    # 3. 坐标轴设置 (Log-Log)
    ax.set_xscale('log')
    ax.set_yscale('log')
    ax.set_xlim(1e-4, 50)
    ax.set_ylim(1e-4, 50)
    
    # 4. 统计信息标注 (Spearman & Shared BCs)
    stats_text = f"Spearman $\\rho$ = {stats['Spearman_Rho']:.3f}\nShared BCs = {int(stats['Shared_BCs']):,}"
    ax.text(0.05, 0.95, stats_text, transform=ax.transAxes, 
            fontsize=10, fontweight='bold', va='top', ha='left',
            bbox=dict(boxstyle="round,pad=0.3", fc="white", alpha=0.8, ec="none"))
    
    # 5. 美化标签
    ax.set_title(group, fontsize=14, fontweight='bold', color=color, pad=10)
    ax.set_xlabel('Plasmid Frequency (%)', fontsize=12)
    if i == 0: 
        ax.set_ylabel('EnvA Frequency (%)', fontsize=12) # 只在最左侧图画Y轴标签
    else:
        ax.set_ylabel('')
        
    sns.despine(ax=ax)

# ==========================================
# 保存与展示
# ==========================================
plt.tight_layout()
save_path = plot_dir / "Supp_Panel_Clonal_Correlation.svg"
plt.savefig(save_path, dpi=300)
plt.show()